# Copy to .env and fill in.
# Database — Postgres (Neon free tier). Two strings from the Neon dashboard:
DATABASE_URL=""   # POOLED connection (host has "-pooler"), add ?sslmode=require — used at runtime
DIRECT_URL=""     # DIRECT connection — used by prisma db push / migrations

AUTH_SECRET=""                        # any long random string; signs session cookies
CRON_SECRET=""                        # protects the reminder cron endpoint
CRON_LOOKBACK_MIN="2"                 # set to your pinger interval (minutes) + 1

# Web Push — generate with:  npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""       # same value as VAPID_PUBLIC_KEY (exposed to client)
VAPID_CONTACT="mailto:you@example.com"

NEXT_PUBLIC_APP_URL="http://localhost:3000"   # in prod, your deployed https URL

# Optional sources
TMDB_API_KEY=""                       # themoviedb.org v3 key for movie/TV releases
THESPORTSDB_API_KEY=""                # thesportsdb.com premium key ($9/mo Patreon) — small leagues + TV listings
APISPORTS_API_KEY=""                  # api-sports.io key — same key works across all their per-sport APIs

